# =============================================================================
# Forge — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/forge
SYNC_DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/forge
CHECKPOINT_DB_URI=postgresql://postgres:password@localhost:5432/forge

# --- LLM Provider ---
# openai_compatible | ollama | airllm
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=local-execution
LLM_MODEL_NAME=qwen2.5-coder:32b
EMBEDDING_MODEL_NAME=nomic-embed-text

# Backward-compatible aliases (can be kept in sync with LLM_*).
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_API_KEY=local-execution
VLLM_MODEL_NAME=qwen2.5-coder:32b

# AirLLM direct-mode knobs (used when provider-specific integration is enabled)
AIRLLM_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct
AIRLLM_DEVICE=cuda:0
AIRLLM_MAX_NEW_TOKENS=4096
AIRLLM_MAX_INPUT_TOKENS=4096

# --- Workspace ---
WORKSPACE_ROOT=./workspaces

# --- Agent ---
MAX_RETRIES=3
ERROR_CEILING=5
TASK_TIMEOUT_SECONDS=3600
CRON_MAX_CONCURRENT_TASKS=4
CRON_POLL_INTERVAL_SECONDS=5
STREAM_POLL_INTERVAL_SECONDS=2
MCP_CONNECT_TIMEOUT_SECONDS=15

# --- Supabase (realtime layer — Phase 2+) ---
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- Security ---
API_BEARER_TOKEN=change-me-in-production

# --- Docker Sandbox ---
SANDBOX_IMAGE=forge-sandbox:latest
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0
